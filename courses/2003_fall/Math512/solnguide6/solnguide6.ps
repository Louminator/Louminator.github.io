% The following draws a box around the plot,
% if the variable drawborder is true
drawborder { 
/bd boundarythick 2 idiv def
[] 0 setdash 
NP bd bd m bd 6923 bd sub l 
5000 bd sub 6923 bd sub l 
5000 bd sub bd l 
bd bd l S
} if % end of if to draw the border

