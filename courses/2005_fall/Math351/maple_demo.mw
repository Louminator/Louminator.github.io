<Worksheet><Version major="6" minor="0"/><View-Properties><Zoom percentage="100"/></View-Properties><Styles><Layout alignment="centred" bullet="none" name="Author" spaceabove="8.0" spacebelow="8.0"/><Layout alignment="left" bullet="none" name="Heading 1" spaceabove="8.0" spacebelow="4.0"/><Layout alignment="left" bullet="none" firstindent="0.0" leftmargin="0.0" linebreak="space" name="Normal" rightmargin="0.0" spaceabove="0.0" spacebelow="0.0"/><Layout alignment="centred" bullet="none" name="Title" spaceabove="12.0" spacebelow="12.0"/><Font background="[0,0,0]" bold="false" family="Lucida Bright" foreground="[0,0,0]" italic="false" name="Text" opaque="false" size="12" underline="false"/><Font background="[0,0,0]" family="Lucida Bright" name="Author" opaque="false" size="12"/><Font background="[0,0,0]" bold="true" family="Serif" name="Heading 1" opaque="false" size="18"/><Font background="[0,0,0]" bold="true" executable="true" family="Monospaced" foreground="[255,0,0]" name="Maple Input" opaque="false" size="12"/><Font background="[0,0,0]" bold="true" family="Lucida Bright" name="Title" opaque="false" size="18" underline="true"/></Styles><Group><Input><Text-field firstindent="0.0" layout="Title" leftmargin="0.0" linebreak="space" rightmargin="0.0" style="Title">Some linear algebra with Maple</Text-field><Text-field firstindent="0.0" layout="Author" leftmargin="0.0" linebreak="space" rightmargin="0.0" style="Author"><Font bold="true" foreground="[0,0,0]" italic="false" underline="true">L.F. Rossi
Math 351 Spring 2005</Font></Text-field><Text-field layout="Normal" style="Text"/><Text-field layout="Normal" style="Text"/><Text-field layout="Normal" style="Text"/><Text-field layout="Normal" prompt="&gt; " style="Maple Input">with(LinearAlgebra);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"/></Input></Group><Section collapsed="true"><Title><Text-field layout="Heading 1" style="Heading 1">Simple things.</Text-field></Title><Text-field layout="Normal" style="Text"/><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">u := &lt;1,2,3&gt;;</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">v := &lt;2|3|4&gt;;</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">u.v;</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">v.u;</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">A := &lt;&lt;3,0,-1&gt;|&lt;2,3,0&gt;|&lt;-1,1,-2&gt;&gt;;</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">A + 2*u.v;</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">A.u;</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">A.(u.v);</Text-field></Input></Group></Section><Section collapsed="true"><Title><Text-field layout="Heading 1" style="Heading 1">Gram Schmidt.</Text-field></Title><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">GramSchmidt([&lt;1,2,1&gt;,&lt;2,1,-1&gt;,&lt;3,0,-1&gt;]);</Text-field></Input></Group></Section><Section collapsed="true"><Title><Text-field layout="Heading 1" style="Heading 1">Inverses and solving linear systems.</Text-field></Title><Text-field layout="Normal" style="Text"/><Text-field layout="Normal" style="Text"/><Group><Input><Text-field layout="Normal" style="Text">If you want to check your solution you can ask Maple to find the inverse.</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">A := &lt;&lt;2,12,3&gt;|&lt;3,1,4&gt;|&lt;-5,0,1&gt;&gt;;</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">MatrixInverse(A);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" style="Text">Or, if you want to check your work step by step, you can have Maple walk through each problem with  you.
Enter your augmented matrix and apply row operations.</Text-field><Text-field layout="Normal" prompt="&gt; " style="Maple Input">A := &lt;&lt;2,12,3&gt;|&lt;3,1,4&gt;|&lt;-5,0,1&gt;|&lt;1,0,0&gt;|&lt;0,1,0&gt;|&lt;0,0,1&gt;&gt;;</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">B:=RowOperation(A,[2,1],-6);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">C:=RowOperation(B,[3,1],-3/2);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">E:=RowOperation(C,[3,2],-1/2/17);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">F:=RowOperation(E,[2,3],-30/259*34);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">G:=RowOperation(F,[1,3],5*34/259);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">H:=RowOperation(G,[1,2],3/17);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">J:=RowOperation(H,1,1/2);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">K:=RowOperation(J,2,-1/17);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">L:=RowOperation(K,3,34/259);</Text-field></Input></Group><Text-field layout="Normal" style="Text"/><Text-field layout="Normal" style="Text">Or, solving Ax = b.</Text-field><Text-field layout="Normal" style="Text"/><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">A := &lt;&lt;2,12,3&gt;|&lt;3,1,4&gt;|&lt;-5,0,1&gt;&gt;; b := &lt;1,1,1&gt;;</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">GaussianElimination(&lt;A|b&gt;);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">ReducedRowEchelonForm(&lt;A|b&gt;);</Text-field></Input></Group><Text-field layout="Normal" style="Text"/><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"/></Input></Group></Section><Section collapsed="true"><Title><Text-field layout="Heading 1" style="Heading 1">Eigensystems.</Text-field></Title><Text-field layout="Normal" style="Text"/><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">A := &lt;&lt;7,1,-1&gt;|&lt;2,1,-5&gt;|&lt;-2,-5,1&gt;&gt;;</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">Eigenvalues(A);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">evalf(Eigenvalues(A));</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">(evals,evecs) := Eigenvectors(A);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">evals;</Text-field></Input></Group><Group><Input><Text-field layout="Normal" style="Text">Now, you must pick apart the evecs.</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">evecs[1..3,1];</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">evalf(evecs[1..3,2]);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" style="Text">Or you can find the characteristic polynomial.</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">A := &lt;&lt;6,1,-1&gt;|&lt;2,1,-5&gt;|&lt;-2,-5,1&gt;&gt;;
</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">p:=CharacteristicPolynomial(A,lambda);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">factor(p);</Text-field></Input></Group></Section><Group><Input><Text-field layout="Normal" style="Text"/></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"/></Input></Group><Text-field/><Text-field/><Text-field/></Worksheet>